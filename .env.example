# DATABASE CONFIGURATION
# Set to PostgreSQL connection string. During development, this points to the Docker container database.
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/richcards?schema=public"

# CACHING CONFIGURATION (Redis)
REDIS_URL="redis://localhost:6379"

# BACKEND SERVER CONFIGURATION
PORT=4000
NODE_ENV=development

# JWT AUTH CONFIGURATION
JWT_SECRET="supersecretjwtsecretkeychangeinproduction"
JWT_EXPIRATION="3600s"
JWT_REFRESH_SECRET="supersecretrefreshkeychangeinproduction"
JWT_REFRESH_EXPIRATION="7d"

# FILE STORAGE CONFIGURATION (Defaults to local disk storage if AWS keys are empty)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME=""

# WHATSAPP INTEGRATION
WHATSAPP_PHONE_NUMBER="+919016705775"

# FRONTEND CONFIGURATION
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
