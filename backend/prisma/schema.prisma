datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  blogs        Blog[]
  activityLogs ActivityLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  action      String   // e.g. "create", "read", "update", "delete", "manage"
  subject     String   // e.g. "Template", "Blog", "User", "all"
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([action, subject])
}

model Template {
  id              String       @id @default(uuid())
  title           String
  slug            String       @unique
  description     String
  price           Decimal      @default(0.00)
  previewVideoUrl String?
  imageUrls       String[]
  watermarked     Boolean      @default(true)
  watermarkId     String?
  watermark       Watermark?   @relation(fields: [watermarkId], references: [id])
  categoryId      String
  category        Category     @relation(fields: [categoryId], references: [id])
  tags            Tag[]        @relation("TemplateTags")
  displayOrder    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  leads           Lead[]
  seoMetadata     SeoMetadata?
}

model Category {
  id               String       @id @default(uuid())
  name             String
  slug             String       @unique
  parentCategoryId String?
  parentCategory   Category?    @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subCategories    Category[]   @relation("CategoryHierarchy")
  displayOrder     Int          @default(0)
  icon             String?
  bannerImage      String?
  templates        Template[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  seoMetadata      SeoMetadata?
}

model Tag {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  templates   Template[]   @relation("TemplateTags")
  blogs       Blog[]       @relation("BlogTags")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  seoMetadata SeoMetadata?
}

model Media {
  id           String   @id @default(uuid())
  filename     String
  filepath     String
  sizeBytes    Int
  format       String
  folder       String   @default("general")
  isCompressed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Blog {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  content     String
  featuredImg String?
  readingTime Int           @default(1)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  categoryId  String
  category    BlogCategory  @relation(fields: [categoryId], references: [id])
  tags        Tag[]         @relation("BlogTags")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  seoMetadata SeoMetadata?
}

model BlogCategory {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  displayOrder Int      @default(0)
  blogs        Blog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id         String    @id @default(uuid())
  name       String
  phone      String
  email      String?
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])
  source     String    @default("WhatsApp")
  status     String    @default("New") // "New", "Contacted", "Interested", "Closed", "Rejected"
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  message    String
  videoUrl   String?
  imageUrl   String?
  isApproved Boolean  @default(false)
  isFeatured Boolean  @default(false)
  rating     Int      @default(5)
  createdAt  DateTime @default(now())
}

model HeroBanner {
  id           String    @id @default(uuid())
  title        String
  subtitle     String?
  imageUrl     String?
  videoUrl     String?
  ctaLink      String?
  ctaText      String?
  displayOrder Int       @default(0)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

model Watermark {
  id        String     @id @default(uuid())
  name      String
  filepath  String
  opacity   Float      @default(0.5)
  position  String     @default("center") // "center", "tile", "top-left", etc.
  isGlobal  Boolean    @default(false)
  isActive  Boolean    @default(true)
  templates Template[]
  createdAt DateTime   @default(now())
}

model SeoMetadata {
  id          String    @id @default(uuid())
  title       String?
  description String?
  keywords    String[]
  ogImage     String?
  schema      String?   // JSON-LD schema markup
  templateId  String?   @unique
  template    Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  categoryId  String?   @unique
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tagId       String?   @unique
  tag         Tag?      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  blogId      String?   @unique
  blog        Blog?     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
